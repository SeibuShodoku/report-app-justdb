REPORT_LINK_SECRET=replace-with-32+chars-secret
REPORT_STORAGE_DIR=data/reports

# Supabase（JUST.DB薬剤資材ミラー / ケースデータ取得）。サーバー専用・クライアントへ渡さない。
# 実値は .env.local に記入すること（.env.local は Git 管理外）。
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# 画像プロキシ BFF / 案件ダイジェスト「口」（Slack写真報告書）。サーバー専用・クライアントへ渡さない。
# Drive は「社内ユーザーの OAuth refresh token」方式（dispatch-app 標準）。外部SAは社内Drive継承が効かず不可。
# client_id/secret は既存OAuthクライアント流用可。発行は OAuth Playground（mgmt-strat 同意）。手順: docs/spec/slack-photo-report-impl-plan.md §1a。
GOOGLE_CLIENT_ID=replace-with-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace-with-oauth-client-secret
# 読み取り用（scope=drive.readonly）。ローカル開発の写真読み取り。
GOOGLE_DRIVE_REFRESH_TOKEN=replace-with-drive-readonly-refresh-token
# 書き込み用（scope=drive full）。「口」のAI専用フォルダ作成・md書込用。
#   ※ Cloud Run(report-app) と VMワーカー はともに GOOGLE_DRIVE_REFRESH_TOKEN に "このRW値" を設定（read+write 兼用）。
#     VMワーカーは Option A＝digest.md を Drive 直書きするため RW（D-DIGEST 項5。旧称 readonly は撤回）。
GOOGLE_DRIVE_RW_REFRESH_TOKEN=replace-with-drive-readwrite-refresh-token
# AI専用サブフォルダ名（既定 _ai）。「口」/ワーカー/写真版履歴が共用（src・worker 両方が読む）。
AI_WORKSPACE_FOLDER_NAME=_ai
# VM常駐ワーカー↔WEB のサーバー間共有シークレット（x-proxy-secret ヘッダ）。
DRIVE_PROXY_SERVER_SECRET=replace-with-32+chars-secret
