REPORT_LINK_SECRET=replace-with-32+chars-secret
REPORT_STORAGE_DIR=data/reports

# Supabase（JUST.DB薬剤資材ミラー / ケースデータ取得）。サーバー専用・クライアントへ渡さない。
# 実値は .env.local に記入すること（.env.local は Git 管理外）。
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# 画像プロキシ BFF（Slack写真報告書）。サーバー専用・クライアントへ渡さない。
# GOOGLE_SA_KEY_JSON: Drive 読み取り用サービスアカウント鍵JSONを1行で（対象フォルダをSAに共有 or 共有ドライブ）。
# DRIVE_PROXY_SERVER_SECRET: VM常駐ワーカー↔WEB のサーバー間共有シークレット（x-proxy-secret ヘッダ）。
GOOGLE_SA_KEY_JSON={"type":"service_account","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","token_uri":"https://oauth2.googleapis.com/token"}
DRIVE_PROXY_SERVER_SECRET=replace-with-32+chars-secret
